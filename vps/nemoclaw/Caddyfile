{
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

nemopod.com {
	reverse_proxy nemoclaw-ui:3000
}

app.nemopod.com {
	handle /trpc/* {
		reverse_proxy nemoclaw-platform:3100
	}
	handle /api/* {
		reverse_proxy nemoclaw-platform:3100
	}
	handle {
		reverse_proxy nemoclaw-ui:3000
	}
}

api.nemopod.com {
	reverse_proxy nemoclaw-platform:3100
}

*.nemopod.com {
	reverse_proxy nemoclaw-platform:3100
}

staging.nemopod.com {
	reverse_proxy staging-ui:3000
}

staging.app.nemopod.com {
	handle /trpc/* {
		reverse_proxy staging-api:3100
	}
	handle /api/* {
		reverse_proxy staging-api:3100
	}
	handle {
		reverse_proxy staging-ui:3000
	}
}

staging.api.nemopod.com {
	reverse_proxy staging-api:3100
}
