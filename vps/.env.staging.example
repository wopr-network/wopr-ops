# Staging environment variables — add these to each VPS .env file
# These are REQUIRED for staging to work alongside prod.

# Auth secret for staging sessions (must differ from prod BETTER_AUTH_SECRET)
# Generate with: openssl rand -hex 32
STAGING_BETTER_AUTH_SECRET=

# Staging DB password (defaults to 'staging-pw' if not set — change in production)
STAGING_POSTGRES_PASSWORD=

# Caddy basic auth credentials for staging endpoints
# Username: staging
# Password: <see-org-secrets>
# Hash must be generated per-VPS: docker exec <caddy-container> caddy hash-password --plaintext '<see-org-secrets>'

# Optional overrides (fall back to prod values if not set)
# STAGING_STRIPE_WEBHOOK_SECRET=
# STAGING_PLATFORM_SECRET=
# STAGING_PLATFORM_ENCRYPTION_SECRET=

# Dummy Resend key (EMAIL_DISABLED=true prevents actual sends)
RESEND_API_KEY=re_staging_disabled
