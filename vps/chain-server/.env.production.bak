# Chain Server — Production Secrets
# Copy to /opt/chain-server/.env on the VPS

# --- Postgres ---
POSTGRES_PASSWORD=REPLACE_ME

# --- Bitcoin ---
BITCOIN_NETWORK=mainnet
BTCPAY_BITCOIND_PASSWORD=REPLACE_ME
CREATE_WALLET=false

