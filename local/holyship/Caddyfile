# Holy Ship — production Caddyfile
#
# Caddy auto-provisions TLS via Let's Encrypt.
# DNS must point api.holyship.wtf and holyship.wtf at this server.
#
# For local dev, replace with:
#   tls internal
# and add "127.0.0.1 holyship.wtf api.holyship.wtf" to hosts file.

holyship.wtf, www.holyship.wtf {
	reverse_proxy ui:3000
}

api.holyship.wtf {
	reverse_proxy api:3001
}
